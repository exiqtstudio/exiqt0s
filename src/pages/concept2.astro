---
import '../styles/global.css';

const row1 = [
  { file: 'Gmail.svg',                 alt: 'Gmail' },
  { file: 'Microsoft-Outlook.svg',     alt: 'Outlook' },
  { file: 'whatsApp.svg',              alt: 'WhatsApp' },
  { file: 'Slack.svg',                 alt: 'Slack' },
  { file: 'Zoom1.svg',                 alt: 'Zoom' },
  { file: 'Google_Meet.svg',           alt: 'Google Meet' },
  { file: 'Google-Calendar.svg',       alt: 'Google Calendar' },
  { file: 'Microsoft_Outlook_Cal.svg', alt: 'Outlook Calendar' },
  { file: 'Stripe.svg',                alt: 'Stripe' },
  { file: 'xero.svg',                  alt: 'Xero' },
  { file: 'QuickBooks.svg',            alt: 'QuickBooks' },
  { file: 'PayPal.svg',                alt: 'PayPal' },
  { file: 'Square.svg',                alt: 'Square' },
  { file: 'Shopify.svg',               alt: 'Shopify' },
];

const row2 = [
  { file: 'Instagram.svg',             alt: 'Instagram' },
  { file: 'facebook.svg',              alt: 'Facebook' },
  { file: 'Linkedin.svg',              alt: 'LinkedIn' },
  { file: 'meta.svg',                  alt: 'Meta' },
  { file: 'tiktok.svg',                alt: 'TikTok' },
  { file: 'mailchimp-mono.svg',        alt: 'Mailchimp', light: true },
  { file: 'Google-ads.svg',            alt: 'Google Ads' },
  { file: 'Zapier.svg',                alt: 'Zapier' },
  { file: 'Google-Drive.svg',          alt: 'Google Drive' },
  { file: 'Dropbox.svg',               alt: 'Dropbox' },
  { file: 'Microsoft-Onedrive.svg',    alt: 'OneDrive' },
  { file: 'box.svg',                   alt: 'Box' },
  { file: 'Hubspot.svg',               alt: 'HubSpot' },
  { file: 'Salesforce.svg',            alt: 'Salesforce' },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>EX!QT 0S — Concept 2</title>
  <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
  <style>
    /* ── Nav brand ── */
    .c2-nav-brand {
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .c2-nav-logo {
      height: 24px;
      width: auto;
      display: block;
    }

    .c2-nav-os {
      font-family: 'IBM Plex Mono', monospace;
      font-weight: 600;
      font-size: 28px;
      letter-spacing: 0.04em;
      color: #616161;
      line-height: 1;
    }

    /* ── Concept 2 hero — split layout ── */
    .c2-hero {
      min-height: 100vh;
      padding-top: 64px;
      padding-bottom: 120px;
      display: flex;
      align-items: stretch;
      overflow: hidden;
      position: relative;
    }

    .c2-hero-inner {
      width: 100%;
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 48px 0 40px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: center;
    }

    /* Left — h1 centred, copy hangs below via wrapper */
    .c2-hero-left {
      display: flex;
      align-items: center;
      height: 100%;
    }

    .c2-h1-wrap {
      position: relative;
    }

    .c2-h1 {
      font-family: 'Switzer', system-ui, sans-serif;
      font-weight: 600;
      color: var(--dark);
      display: flex;
      flex-direction: column;
      gap: 0;
      width: 560px;
    }

    .c2-h1 span {
      display: block;
      white-space: nowrap;
      line-height: 1.0;
    }

    .c2-h1-run          { font-size: 292px; margin-left: -14px; }
    .c2-h1-the-business { font-size: 87px; margin-top: -18px; }
    .c2-h1-rest         { font-size: 72px; margin-top: 10px; }

    /* Right — orbital centred, stage at natural scale */
    .c2-hero-right {
      position: relative;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: visible;
    }

    .c2-copy {
      position: absolute;
      top: calc(100% + 40px);
      left: 0;
      width: 560px;
      display: flex;
      flex-direction: column;
      gap: 24px;
    }

    .c2-body {
      font-size: 19px;
      font-weight: 400;
      color: var(--muted);
      line-height: 1.65;
    }

    .c2-copy .os-hero-btn-primary {
      width: fit-content;
    }

    /* Card boost — stronger presence */
    .card {
      border-left: 3px solid rgba(255,255,255,0.7) !important;
      box-shadow:
        0 1px 0 0 rgba(255,255,255,0.9) inset,
        0 0 0 0.5px rgba(14,17,22,0.10),
        0 8px 32px rgba(14,17,22,0.14),
        0 2px 8px rgba(14,17,22,0.10) !important;
    }

    .c2-hero-right .stage {
      transform: scale(0.85) translateY(-50px);
      transform-origin: center center;
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav class="os-nav-1-2-3-4">
    <a href="/" class="c2-nav-brand">
      <svg class="c2-nav-logo" viewBox="0 -61 1261.44 254" xmlns="http://www.w3.org/2000/svg" aria-label="EX!QT">
        <path transform="translate(2.4,-50.264)" fill="#616161" fill-rule="evenodd" d="M29.7321 209.76L4.86945 209.76C1.66945 208.322 0.0694549 206.717 0.0694549 204.944L0.047017 174.42C0.0395377 127.76 0.0320584 81.1 0.0245791 34.44C0.00338021 24.3388 -0.0392306 14.7562 0.0845791 4.8C0.0845791 2.14903 2.01871 0 4.40458 0C10.3807 0.0772014 18.6599 0.0772014 29.242 0C87.9689 0 144.293 0 203.02 0C204.406 0 205.53 1.07452 205.53 2.4C205.53 14.08 205.53 25.76 205.53 37.44C205.53 38.7655 204.406 39.84 203.02 39.84C163.797 39.84 109.732 39.84 40.8246 39.84C40.1982 39.7432 39.6447 40.3773 39.6478 41.04C39.6115 54.6992 39.5662 68.3494 39.8413 82.32C39.8444 82.9827 40.0368 83.52 40.6995 83.52C92.7395 83.52 146.225 83.52 198.265 83.52C199.59 83.52 200.665 84.5945 200.665 85.92L200.665 120.96C200.665 122.285 199.59 123.36 198.265 123.36C155.053 123.283 112.425 123.799 68.9046 123.36L41.0646 123.36C40.4018 123.36 39.8646 123.897 39.8646 124.56L39.8646 169.44C40.2596 170.721 40.7396 171.281 41.3046 171.12C113.097 171.04 167.487 171 204.474 171C205.899 171 207.054 172.045 207.054 173.335L207.054 207.425C207.054 208.715 205.899 209.76 204.474 209.76Z"/>
        <path transform="translate(285.093,-50.264)" fill="#616161" d="M118.32 132.48C103.707 149.6 81.6267 175.28 52.08 209.52L0 209.76L92.64 103.44C51.5796 57.6326 20.7796 23.2326 0.24 0.24L52.56 0C67.0667 16.2504 88.9867 40.6504 118.32 73.2L183.36 0L235.44 0L143.04 103.44C163.547 127.067 194.636 162.474 236.308 209.663L183.36 209.76C152.561 173.052 130.881 147.292 118.32 132.48Z"/>
        <rect transform="translate(597.84,-50.384)" fill="#616161" width="42.105" height="143.28" rx="2.4" ry="2.4"/>
        <rect transform="translate(597.84,119.595)" fill="#616161" width="42.015" height="40.005" rx="2.4" ry="2.4"/>
        <path transform="translate(722.957,-51.12)" fill="#616161" fill-rule="evenodd" d="M121.14 209.749C153.25 209.875 168.819 209.79 176.16 209.76C165.36 196.48 154.56 183.2 143.76 169.92C113.16 169.92 82.0181 169.378 51.96 169.92C45.0675 169.92 39.48 164.333 39.48 157.44L39.48 52.32C39.48 45.4275 45.0675 39.84 51.96 39.84C97.64 39.84 143.32 39.84 189 39.84C195.893 39.84 201.48 45.4275 201.48 52.32L201.48 157.44C201.48 160.065 202.286 165.187 198.69 165.256C189.97 155.256 182.18 145.632 173.46 135.632C162.9 135.632 147.14 135.632 126.18 135.632C153.232 169.06 180.538 202.525 208.138 234.512C235.659 234.512 252.18 234.512 257.7 234.512M121.016 209.741C84.0454 209.754 61.9467 209.76 54.72 209.76C26.6198 209.76 0 186.98 0 158.88C0.04 122.88 0.08 86.88 0.12 50.88C0.12 22.7798 22.8998 0 51 0C97.6401 0 144.28 0 190.92 0C219.02 0 241.8 22.7798 241.8 50.88L241.65 161.49C241.167 173.361 235.828 183.6 227.742 190.854C227.202 191.339 225.598 192.726 222.93 195.016L255.06 233.792M187.68 209.76"/>
        <path transform="translate(1033.967,-50.264)" fill="#616161" d="M132.72 39.78L220.32 39.84C221.645 39.84 222.72 38.7655 222.72 37.44L222.72 2.4C222.72 1.07452 221.645 0 220.32 0L2.4 0C1.07452 0 0 1.07452 0 2.4L0 37.44C0 38.7655 1.07452 39.84 2.4 39.84C32.16 39.84 60.3898 40.3502 91.68 39.84L91.68 207.36C91.68 208.685 92.7545 209.76 94.08 209.76L130.32 209.76C131.645 209.76 132.72 208.685 132.72 207.36Z"/>
      </svg>
      <span class="c2-nav-os">0S</span>
    </a>
    <div class="os-nav-links-1-2-3">
      <a href="#product"  class="os-nav-link-1-2-3-4">Product</a>
      <a href="#sectors"  class="os-nav-link-1-2-3-4">Sectors</a>
      <a href="#pricing"  class="os-nav-link-1-2-3-4">Pricing</a>
    </div>
    <div class="os-nav-actions-1">
      <a href="https://exiqt.app/login" class="os-nav-secondary-1-2">Log in</a>
      <a href="#trial"       class="os-nav-cta-1-2-3-4">Get started</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="c2-hero">
    <div class="c2-hero-inner">

      <div class="c2-hero-left">
        <div class="c2-h1-wrap">
          <h1 class="c2-h1">
            <span class="c2-h1-run">Run</span>
            <span class="c2-h1-the-business">the business</span>
            <span class="c2-h1-rest">you intended to</span>
          </h1>
          <div class="c2-copy">
            <p class="c2-body">One operational environment for every part of your business.<br />Connected, automated and visible the way it should always be.</p>
            <a href="#trial" class="os-hero-btn-primary">Get started</a>
          </div>
        </div>
      </div>

      <div class="c2-hero-right">
        <div class="stage" id="orbital-stage">
          <div class="core-glow"></div>
          <div class="core-bracket">
            <span></span><span></span><span></span><span></span>
          </div>
          <div class="core">
            <div class="core-os">
              <div class="core-os-zero">
                <span>0</span>
                <div class="core-os-dot"></div>
              </div>
              <span class="core-os-s">S</span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- RECOGNITION -->
  <section class="os-recognition">
    <div class="os-recognition-inner">
      <p class="os-recognition-statement">Good systems preserve what people cannot get back</p>
    </div>
  </section>

  <!-- PRODUCT -->
  <section class="crm-section" id="product">
    <div class="crm-section-inner">
      <div class="crm-section-header">
        <h2 class="crm-headline">Your pipeline.<br/>Always moving.</h2>
        <p class="crm-subline">EXIQT 0S automates the follow-through so nothing falls between the cracks.</p>
      </div>
      <div class="crm-window">
        <!-- Browser chrome -->
        <div class="crm-chrome">
          <div class="crm-dots">
            <span class="crm-dot crm-dot-red"></span>
            <span class="crm-dot crm-dot-yellow"></span>
            <span class="crm-dot crm-dot-green"></span>
          </div>
          <div class="crm-tab-label">Opportunities — EXIQT 0S</div>
          <div class="crm-address">
            <svg width="10" height="12" viewBox="0 0 10 12" fill="none"><path d="M5 1a3 3 0 00-3 3v1H1.5A.5.5 0 001 5.5v5a.5.5 0 00.5.5h7a.5.5 0 00.5-.5v-5a.5.5 0 00-.5-.5H8V4a3 3 0 00-3-3zm-2 3a2 2 0 014 0v1H3V4z" fill="#6B7280"/></svg>
            <span>app.exiqt0s</span>
          </div>
        </div>
        <!-- App frame -->
        <div class="crm-app" id="crm-pipeline">
          <!-- Sidebar -->
          <nav class="crm-sidebar">
            <div class="crm-sidebar-brand">0S</div>
            <div class="crm-sidebar-nav">
              <div class="crm-nav-item">Dashboard</div>
              <div class="crm-nav-item">Conversations</div>
              <div class="crm-nav-item">Contacts</div>
              <div class="crm-nav-item crm-nav-active">Opportunities</div>
              <div class="crm-nav-item">Calendars</div>
              <div class="crm-nav-item">AI Agents</div>
              <div class="crm-nav-item">Automation</div>
              <div class="crm-nav-item">Payments</div>
            </div>
          </nav>
          <!-- Main -->
          <div class="crm-main">
            <div class="crm-topbar">
              <div class="crm-title">Opportunities</div>
              <div class="crm-tabs">
                <span class="crm-tab-item crm-tab-active">Opportunities</span>
                <span class="crm-tab-item">Forecast</span>
                <span class="crm-tab-item">Pipelines</span>
              </div>
            </div>
            <div class="crm-toolbar">
              <div class="crm-pipeline-select">Client Acquisition ▾</div>
              <span class="crm-opp-count" id="opp-count">5 opportunities</span>
            </div>
            <div class="crm-pipeline">
              <div class="crm-stage">
                <div class="crm-stage-header">
                  <span class="crm-stage-name">New Enquiry</span>
                  <span class="crm-stage-count" id="crm-count-new">0</span>
                </div>
                <div class="crm-stage-cards" id="crm-cards-new"></div>
              </div>
              <div class="crm-stage">
                <div class="crm-stage-header">
                  <span class="crm-stage-name">Contacted</span>
                  <span class="crm-stage-count" id="crm-count-contacted">0</span>
                </div>
                <div class="crm-stage-cards" id="crm-cards-contacted"></div>
              </div>
              <div class="crm-stage">
                <div class="crm-stage-header">
                  <span class="crm-stage-name">Appointment</span>
                  <span class="crm-stage-count" id="crm-count-appointment">0</span>
                </div>
                <div class="crm-stage-cards" id="crm-cards-appointment"></div>
              </div>
              <div class="crm-stage">
                <div class="crm-stage-header">
                  <span class="crm-stage-name">Proposal</span>
                  <span class="crm-stage-count" id="crm-count-proposal">0</span>
                </div>
                <div class="crm-stage-cards" id="crm-cards-proposal"></div>
              </div>
              <div class="crm-stage">
                <div class="crm-stage-header">
                  <span class="crm-stage-name">Closed</span>
                  <span class="crm-stage-count" id="crm-count-closed">0</span>
                </div>
                <div class="crm-stage-cards" id="crm-cards-closed"></div>
              </div>
            </div>
          </div>
        </div>
        <!-- Toast -->
        <div class="crm-toast" id="crm-toast">
          <div class="crm-toast-inner">
            <span class="crm-toast-dot"></span>
            <span class="crm-toast-text"></span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- INTEGRATIONS -->
  <section class="os-integrations" id="integrations">
    <div class="os-integrations-inner">
      <h2 class="os-integrations-headline-new">
        Connects to everything.<br />
        Disrupts nothing.
      </h2>
      <div class="c2-marquee-wrap">
        <div class="c2-marquee-row c2-marquee-left">
          <div class="c2-marquee-track">
            {[...row1, ...row1].map(logo => (
              <div class="os-logo-cell">
                <img class={logo.light ? 'os-logo-img-light' : 'os-logo-img'} src={`/logos/${logo.file}`} alt={logo.alt} loading="lazy" />
              </div>
            ))}
          </div>
        </div>
        <div class="c2-marquee-row c2-marquee-right">
          <div class="c2-marquee-track">
            {[...row2, ...row2].map(logo => (
              <div class="os-logo-cell">
                <img class={logo.light ? 'os-logo-img-light' : 'os-logo-img'} src={`/logos/${logo.file}`} alt={logo.alt} loading="lazy" />
              </div>
            ))}
          </div>
        </div>
      </div>
      <div class="os-integrations-footer-1-2-3">
        <p class="os-integrations-count-1-2-3">If your business runs on it, 0S connects to it.*</p>
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section class="os-pricing" id="pricing">
    <div class="os-pricing-inner">

      <div class="os-pricing-header">
        <p class="os-pricing-eyebrow">Pricing</p>
        <h2 class="os-pricing-headline">One system.<br/>Three scales.</h2>
        <p class="os-pricing-subline">No contracts. No setup fees. Cancel anytime.</p>
      </div>

      <!-- Billing toggle -->
      <div class="os-pricing-toggle-wrap">
        <span class="os-toggle-label os-toggle-label-active" id="lbl-monthly">Monthly</span>
        <button class="os-toggle-btn" id="billing-toggle" aria-pressed="false" aria-label="Switch to annual billing">
          <span class="os-toggle-thumb"></span>
        </button>
        <span class="os-toggle-label" id="lbl-annual">Annual <span class="os-toggle-save">Save 17%</span></span>
      </div>

      <!-- Cards -->
      <div class="os-pricing-cards">

        <!-- STARTER -->
        <div class="os-pricing-card">
          <div class="os-pricing-card-body">
            <p class="os-pricing-tier">Starter</p>
            <div class="os-pricing-price-wrap">
              <span class="os-price-currency">$</span>
              <span class="os-price-amount" data-monthly="149" data-annual="124">149</span>
              <div class="os-price-right">
                <span class="os-price-per">/mo</span>
                <span class="os-price-billing" id="billing-note-0">billed monthly</span>
              </div>
            </div>
            <div class="os-pricing-limits">
              <span>2,500 contacts</span>
              <span class="os-limits-sep">·</span>
              <span>1 user</span>
              <span class="os-limits-sep">·</span>
              <span>1 location</span>
            </div>
            <a href="#trial" class="os-pricing-cta os-pricing-cta-ghost">Start free trial</a>
            <div class="os-feat-groups">
              <div class="os-feat-group">
                <p class="os-feat-cat">Pipeline &amp; CRM</p>
                <ul>
                  <li>Contact management</li>
                  <li>Deal pipeline + stage tracking</li>
                  <li>Task + activity management</li>
                  <li>Activity timeline + notes</li>
                </ul>
              </div>
              <div class="os-feat-group">
                <p class="os-feat-cat">Communications</p>
                <ul>
                  <li>Two-way email + SMS</li>
                  <li>Broadcast campaigns</li>
                  <li>Live web chat widget</li>
                  <li>Missed call text-back</li>
                </ul>
              </div>
              <div class="os-feat-group">
                <p class="os-feat-cat">Booking</p>
                <ul>
                  <li>Online booking page</li>
                  <li>Google + Outlook calendar sync</li>
                  <li>Automated appointment reminders</li>
                </ul>
              </div>
              <div class="os-feat-group">
                <p class="os-feat-cat">Websites &amp; Funnels</p>
                <ul>
                  <li>Website builder (hosted)</li>
                  <li>Landing pages + funnels</li>
                  <li>Forms + survey builder</li>
                </ul>
              </div>
              <div class="os-feat-group">
                <p class="os-feat-cat">Automation</p>
                <ul>
                  <li>Visual workflow builder</li>
                  <li>Automated follow-up sequences</li>
                  <li>Email marketing campaigns</li>
                </ul>
              </div>
              <div class="os-feat-group">
                <p class="os-feat-cat">Reputation</p>
                <ul>
                  <li>Review request automation</li>
                  <li>Google + Facebook review management</li>
                </ul>
              </div>
              <div class="os-feat-group">
                <p class="os-feat-cat">Reporting</p>
                <ul>
                  <li>Pipeline + deal reporting</li>
                  <li>Bookings + activity reporting</li>
                </ul>
              </div>
              <div class="os-feat-group">
                <p class="os-feat-cat">Support</p>
                <ul>
                  <li>Email support</li>
                  <li>Self-serve setup included</li>
                </ul>
              </div>
            </div>
          </div>
        </div>

        <!-- GROWTH -->
        <div class="os-pricing-card os-pricing-card-featured">
          <div class="os-pricing-card-body">
            <p class="os-pricing-tier">Growth</p>
            <div class="os-pricing-price-wrap">
              <span class="os-price-currency">$</span>
              <span class="os-price-amount" data-monthly="249" data-annual="207">249</span>
              <div class="os-price-right">
                <span class="os-price-per">/mo</span>
                <span class="os-price-billing" id="billing-note-1">billed monthly</span>
              </div>
            </div>
            <div class="os-pricing-limits">
              <span>10,000 contacts</span>
              <span class="os-limits-sep">·</span>
              <span>3 users</span>
              <span class="os-limits-sep">·</span>
              <span>1 location</span>
            </div>
            <a href="#trial" class="os-pricing-cta os-pricing-cta-primary">Start free trial</a>
            <div class="os-feat-groups">
              <div class="os-feat-group os-feat-group-inherit">
                <p class="os-feat-cat">Everything in Starter, plus</p>
              </div>
              <div class="os-feat-group">
                <p class="os-feat-cat">AI</p>
                <ul>
                  <li>AI conversation agents (24/7)</li>
                  <li>Voice AI — after-hours call handling</li>
                  <li>AI content generation</li>
                </ul>
              </div>
              <div class="os-feat-group">
                <p class="os-feat-cat">Communications</p>
                <ul>
                  <li>WhatsApp messaging</li>
                </ul>
              </div>
              <div class="os-feat-group">
                <p class="os-feat-cat">Reporting</p>
                <ul>
                  <li>Monthly performance report</li>
                </ul>
              </div>
              <div class="os-feat-group">
                <p class="os-feat-cat">Support</p>
                <ul>
